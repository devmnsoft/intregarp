{
  "ConnectionStrings": {
    "IntegraRP": "Host=localhost;Port=5432;Database=integrarp;Username=<usuario>;Password=<senha>"
  },
  "IntegraRP": {
    "RunMigrations": false,
    "ApiBaseUrl": "http://localhost:7001",
    "Storage": {
      "Provider": "Local",
      "RootPath": "./storage"
    },
    "Database": {
      "MigrationsPath": "database/migrations"
    }
  },
  "Jwt": {
    "Issuer": "IntegraRP",
    "Audience": "IntegraRP.Api"
  }
}
