<!doctype html>
<html lang="pt-br">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>@ViewData["Title"] - IntegraRP</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
  <link rel="stylesheet" href="~/css/app.css" />
  <link rel="stylesheet" href="~/css/components.css" />
<link rel="stylesheet" href="~/css/journey.css" />
<link rel="stylesheet" href="~/css/onboarding.css" />
<link rel="stylesheet" href="~/css/contextual-help.css" />
<link rel="stylesheet" href="~/css/guided-tour.css" />
<link rel="stylesheet" href="~/css/empty-state.css" />
</head>
<body>
  <div class="container-fluid integrarp-shell">
    <div class="row min-vh-100">
      <aside class="col-12 col-lg-2 integrarp-sidebar p-4">
        <div class="mb-4">
          <h1 class="h4 mb-1">IntegraRP</h1>
          <small>Valora Group &amp; MNSoft</small>
        </div>
        <nav class="d-grid gap-2">
          @foreach (var item in new[] { "Dashboard", "Flow", "Designer", "Tarefas", "Execução", "Studio", "Criador", "Dinâmicos", "Integra AI", "Auditoria IA", "BI", "Project Central", "Setores", "Clientes", "Produtos", "Pedidos", "Faturamento", "Connect", "Financeiro", "Logística", "Entregas", "KPIs", "Configurações" })
          {
            <a href='@(item == "Dashboard" ? "/dashboard" : item == "Flow" ? "/flow" : item == "Tarefas" ? "/tasks/my" : item == "Clientes" ? "/customers" : item == "Produtos" ? "/products" : item == "Pedidos" ? "/orders" : item == "Logística" ? "/inventory" : item == "Faturamento" ? "/billing" : item == "Connect" ? "/connect" : item == "BI" ? "/bi" : item == "KPIs" ? "/bi/kpis" : item == "Project Central" ? "/project" : Url.Action("Page", "Home", new { id = item }))'>@item</a>
          }
        </nav>
      </aside>
      <main class="col-12 col-lg-10 p-4">
        <header class="d-flex flex-wrap justify-content-between align-items-center mb-4">
          <div>
            <span class="badge text-bg-primary">Integra Gestão Inteligente</span>
            <p class="mb-0 mt-2">Do pedido ao faturamento, tudo integrado, comunicado e medido.</p>
          </div>
          <a class="btn btn-outline-primary" asp-action="Login">Login visual</a>
        </header>
        @RenderBody()
        <footer class="mt-5 text-muted">© Valora Group &amp; MNSoft - IntegraRP</footer>
      </main>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="~/js/app.js"></script>
  <script src="~/js/api-client.js"></script>
  @await RenderSectionAsync("Scripts", false)
<script src="~/js/journey-api.js"></script>
<script src="~/js/onboarding.js"></script>
<script src="~/js/what-to-do-now.js"></script>
<script src="~/js/contextual-help.js"></script>
<script src="~/js/guided-tour.js"></script>
<script src="~/js/empty-state-guidance.js"></script>
<script src="~/js/user-feedback.js"></script>
</body>
</html>
