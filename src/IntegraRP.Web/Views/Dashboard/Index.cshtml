@model IntegraRP.Web.ViewModels.Dashboard.DashboardViewModel
@{ ViewData["Title"] = "Dashboard executivo"; ViewData["Description"] = "Priorize riscos, gargalos e próximas ações com dados operacionais reais."; }
@section Styles { <link rel="stylesheet" href="~/css/pages/dashboard.css" asp-append-version="true" /> }
<section class="dashboard-hero panel" aria-labelledby="dashboard-heading">
  <div><p class="eyebrow">Bom trabalho</p><h2 id="dashboard-heading">Visão executiva da operação — @Model.TenantName</h2><p>Período atual · última atualização @Model.LastUpdatedAt.ToLocalTime().ToString("g")</p></div>
  <div class="d-flex gap-2"><button class="btn btn-primary" type="button" data-refresh-dashboard>Atualizar</button><a class="btn btn-outline-primary" href="/tasks/my">Ver tarefas</a></div>
</section>
<section class="kpi-grid" aria-label="Indicadores principais">
@foreach (var kpi in Model.Kpis)
{
  <article class="kpi-card" data-status="@kpi.Status"><i class="bi @kpi.Icon" aria-hidden="true"></i><p>@kpi.Title</p><strong>@kpi.Value</strong><span>@kpi.Context</span><a href="@kpi.DetailUrl">Abrir detalhe</a></article>
}
</section>
<section class="dashboard-grid">
  <article class="panel"><h2>O que precisa da sua atenção</h2><p class="text-muted">Nenhum alerta crítico foi retornado pela API. Quando houver dados, priorize atrasos, rupturas e exceções de SLA.</p></article>
  <article class="panel"><h2>Minhas próximas tarefas</h2><p class="text-muted">A lista será preenchida por tarefas atribuídas ao usuário autenticado.</p></article>
  <article class="panel"><h2>Processos em andamento</h2><p class="text-muted">Instâncias do Integra Flow aparecerão aqui com etapa atual e responsável.</p></article>
  <article class="panel"><h2>Saúde dos módulos</h2><p class="text-muted">API, Web, Worker, banco e integrações serão exibidos sem números fictícios em Production.</p></article>
</section>
@section Scripts { <script src="~/js/pages/dashboard.js" asp-append-version="true" defer></script> }
