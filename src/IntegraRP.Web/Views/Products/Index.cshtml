@{ ViewData["Title"] = "Produtos"; }
<section class="integrarp-page"><h1>Produtos</h1><div id="products-status" class="alert alert-info">Carregando produtos reais...</div><form id="product-form" class="card p-3 mb-3"><input type="hidden" name="id" /><div class="row g-2"><div class="col-md-2"><input class="form-control" name="sku" placeholder="SKU" required /></div><div class="col-md-4"><input class="form-control" name="nome" placeholder="Nome" required /></div><div class="col-md-2"><input class="form-control" name="estoqueMinimo" type="number" step="0.01" placeholder="Mínimo" /></div><div class="col-md-2"><input class="form-control" name="estoqueAtual" type="number" step="0.01" placeholder="Atual" /></div><div class="col-md-2 d-grid"><button class="btn btn-primary">Salvar produto</button></div></div></form><div class="table-responsive"><table class="table table-striped"><thead><tr><th>SKU</th><th>Nome</th><th>Estoque</th><th>Mínimo</th><th>Status</th><th>Ações</th></tr></thead><tbody id="products-list"></tbody></table></div></section>
@section Scripts { <script src="~/js/operational-cruds.js"></script><script>IntegraCrud.products();</script> }
