@{ ViewData["Title"] = "Entrada de estoque"; }
<section class="integrarp-page"><h1>Entrada de estoque</h1><div id="inventory-status" class="alert alert-info">Informe SKU e quantidade.</div><form id="inventory-form" class="card p-3"><div class="row g-2"><div class="col-md-5"><input class="form-control" name="sku" placeholder="SKU do produto" required /></div><div class="col-md-3"><input class="form-control" name="quantidade" type="number" step="0.01" value="1" min="0.01" required /></div><div class="col-md-4 d-grid"><button class="btn btn-success">Registrar entrada</button></div></div></form><h2 class="h4 mt-4">Produtos atualizados</h2><div id="inventory-products" class="row g-2"></div></section>
@section Scripts { <script type="module" src="~/js/pages/inventory.js"></script> }
