@{ ViewData["Title"] = "Clientes"; }
<section class="integrarp-page"><h1>Clientes</h1><div id="customers-status" class="alert alert-info">Carregando clientes reais...</div><form id="customer-form" class="card p-3 mb-3"><input type="hidden" name="id" /><div class="row g-2"><div class="col-md-4"><input class="form-control" name="nome" placeholder="Nome" required /></div><div class="col-md-3"><input class="form-control" name="documento" placeholder="Documento" /></div><div class="col-md-3"><input class="form-control" name="email" type="email" placeholder="Email" /></div><div class="col-md-2 d-grid"><button class="btn btn-primary">Salvar cliente</button></div></div></form><div class="table-responsive"><table class="table table-striped"><thead><tr><th>Nome</th><th>Documento</th><th>Email</th><th>Status</th><th>Ações</th></tr></thead><tbody id="customers-list"></tbody></table></div></section>
@section Scripts { <script src="~/js/operational-cruds.js"></script><script>IntegraCrud.customers();</script> }
