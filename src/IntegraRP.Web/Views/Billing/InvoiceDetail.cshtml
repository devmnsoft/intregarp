@model Guid
@{
    ViewData["Title"] = "Detalhe da fatura";
}

<section class="integrarp-page" data-id="@Model">
    <h2>Fatura @Model</h2>
    <div id="invoice-detail" class="card p-3"></div>
    <div class="mt-3 d-flex gap-2">
        <button class="btn btn-success" data-action="issue">Emitir</button>
        <button class="btn btn-primary" data-action="create-title">Gerar título</button>
    </div>
</section>

@section Scripts {
    <script src="~/js/billing-invoices.js"></script>
}
